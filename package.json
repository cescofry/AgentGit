{
  "name": "agentgit",
  "version": "0.1.0",
  "description": "GitHub bot that watches issues, proposes plans, and opens PRs using AI coding agents",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "typecheck": "tsc --noEmit",
    "setup:repo": "ts-node src/setup/cli.ts setup repo",
    "setup:server": "ts-node src/setup/cli.ts setup server",
    "doctor": "ts-node src/setup/cli.ts doctor"
  },
  "keywords": ["github", "bot", "probot", "ai", "agent", "coding"],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "probot": "^13.0.0",
    "js-yaml": "^4.1.0",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.6.0",
    "ts-node": "^10.9.0",
    "nock": "^13.5.0"
  }
}
